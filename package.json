{
  "name": "hello-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "stop": "npx --no-install kill-port 5173 *>$null",
    "status": "npm run _status -s",
    "_status": "node --no-warnings -e \"const net=require('net');const c=p=>new Promise(r=>{const s=new net.Socket();s.setTimeout(500);s.on('connect',()=>{s.destroy();r(1)}).on('error',()=>{r(0)}).on('timeout',()=>{s.destroy();r(0)}).connect(p,'127.0.0.1')});c(5173).then(f=>console.log(f?'\\x1b[32m[+] Frontend (5173) is RUNNING.\\x1b[0m':'\\x1b[31m[-] System is OFFLINE.\\x1b[0m'))\"",
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ghpages": "TEST_URL=https://tng-coop.github.io/hlm/ playwright test",
    "screenshots": "TAKE_SCREENSHOTS=true playwright test tests/manual-screenshots.spec.js",
    "knip": "knip",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "kill-port": "^2.0.1",
    "knip": "^6.1.0",
    "lefthook": "^2.1.4",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  }
}
